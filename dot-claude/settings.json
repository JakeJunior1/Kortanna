{
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "allow": [
      "Bash(launchctl load:*)",
      "Bash(launchctl list:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(vercel whoami:*)",
      "Bash(find ~/.local -name *.json)",
      "Bash(gh repo:*)",
      "Bash(npm install:*)",
      "Bash(npx @openai/codex --version)",
      "Bash(codex --version)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pre-push-review-guard.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/main-protection.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/planner-file-lock.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/merge-gate.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/reviewer-file-lock.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/verifier-file-lock.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/planner-file-lock.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/guide-readonly-guard.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/planning-single-writer.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/reviewer-file-lock.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/verifier-file-lock.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__computer-use__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/computer-use-mutex.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/precompact-guard.sh\" manual"
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/precompact-guard.sh\" auto"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/post-compact-resume.sh\""
          }
        ]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/monitor-reminder.sh\" start",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/monitor-reminder.sh\" check",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/computer-use-mutex-release.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/computer-use-mutex-release.sh\""
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/worktree-create.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/worktree-remove.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "planning-with-files@planning-with-files": false,
    "security-guidance@claude-plugins-official": false,
    "voltagent-data-ai@voltagent-subagents": false,
    "context7@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "serena@claude-plugins-official": false,
    "atlassian@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": false,
    "Notion@claude-plugins-official": false,
    "slack@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": false,
    "sentry@claude-plugins-official": true,
    "gitlab@claude-plugins-official": false,
    "circleback@claude-plugins-official": false,
    "semgrep@claude-plugins-official": false,
    "asana@claude-plugins-official": false,
    "pinecone@claude-plugins-official": true,
    "posthog@claude-plugins-official": true,
    "pagerduty@claude-plugins-official": false,
    "adspirer-ads-agent@claude-plugins-official": false,
    "amazon-location-service@claude-plugins-official": false,
    "aws-serverless@claude-plugins-official": false,
    "data@claude-plugins-official": false,
    "deploy-on-aws@claude-plugins-official": false,
    "legalzoom@claude-plugins-official": false,
    "migration-to-aws@claude-plugins-official": false,
    "mintlify@claude-plugins-official": false,
    "rc@claude-plugins-official": false,
    "sanity-plugin@claude-plugins-official": false,
    "sourcegraph@claude-plugins-official": false,
    "sumup@claude-plugins-official": false,
    "wix@claude-plugins-official": false,
    "engineering@knowledge-work-plugins": false,
    "data@knowledge-work-plugins": false,
    "design@knowledge-work-plugins": false,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "duckdb-skills@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "neon@claude-plugins-official": true,
    "aws-core@claude-plugins-official": false,
    "prisma@claude-plugins-official": false,
    "terraform@claude-plugins-official": false,
    "clickhouse@claude-plugins-official": false,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "cli-anything@cli-anything": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "planning-with-files": {
      "source": {
        "source": "github",
        "repo": "OthmanAdi/planning-with-files"
      }
    },
    "voltagent-subagents": {
      "source": {
        "source": "github",
        "repo": "VoltAgent/awesome-claude-code-subagents"
      }
    },
    "hydradb": {
      "source": {
        "source": "github",
        "repo": "usecortex/hydradb-claude-code"
      }
    },
    "knowledge-work-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/knowledge-work-plugins"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
